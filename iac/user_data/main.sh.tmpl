#!/bin/bash
set -euo pipefail

export DEBIAN_FRONTEND=noninteractive

# Add the specified user
if ! id -u "${ssh_username}" >/dev/null 2>&1; then
  useradd -m -s /bin/bash "${ssh_username}"
fi

# Set the password for the user and make the user a sudoer
echo "${ssh_username}:${ssh_password}" | chpasswd
usermod -aG sudo "${ssh_username}"
echo "${ssh_username} ALL=(ALL:ALL) ALL" > "/etc/sudoers.d/99-${ssh_username}"

# Allow password login on SSH
cat >/etc/ssh/sshd_config.d/99-password-auth.conf <<'EOF'
PasswordAuthentication yes
KbdInteractiveAuthentication yes
EOF
systemctl restart ssh

# Install SSM agent
snap install amazon-ssm-agent --classic
systemctl enable --now snap.amazon-ssm-agent.amazon-ssm-agent.service

# Install Docker
apt-get update
apt-get install -y ca-certificates curl gnupg

install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg

echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo $${VERSION_CODENAME}) stable" > /etc/apt/sources.list.d/docker.list

apt-get update
apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
systemctl enable --now docker

usermod -aG docker "${ssh_username}"